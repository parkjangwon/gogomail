# gogomail Docker Compose Environment Variables

# ===== PostgreSQL =====
POSTGRES_DB=gogomail
POSTGRES_USER=gogomail
POSTGRES_PASSWORD=changeme
POSTGRES_REPL_USER=replicator
POSTGRES_REPL_PASSWORD=repl_password_change_me

# ===== Redis =====
REDIS_PASSWORD=changeme

# ===== MinIO =====
MINIO_ROOT_USER=gogomail
MINIO_ROOT_PASSWORD=changepassword123

# ===== Go Backend =====
BACKEND_IMAGE=gogomail:latest
GOGOMAIL_BACKEND_URL=http://localhost:8080
GOGOMAIL_ENV=development
GOGOMAIL_AUTH_JWT_SECRET=gogomail-dev-jwt-secret
GOGOMAIL_ADMIN_TOKEN=change-this-admin-token
GOGOMAIL_ADMIN_MFA_REQUIRED=false
GOGOMAIL_PUBLIC_BASE_URL=https://mail.example.com
GOGOMAIL_DATABASE_URL=postgres://gogomail:changeme@postgres:5432/gogomail?sslmode=disable
GOGOMAIL_DB_MAX_OPEN_CONNS=20
GOGOMAIL_DB_MAX_IDLE_CONNS=5
GOGOMAIL_DB_CONN_MAX_LIFETIME=30m
GOGOMAIL_DB_CONN_MAX_IDLE_TIME=5m
GOGOMAIL_REDIS_ADDR=redis:6379
GOGOMAIL_REDIS_PASSWORD=changeme
GOGOMAIL_STORAGE_BACKEND=minio
GOGOMAIL_STORAGE_S3_ENDPOINT=http://minio:9000
GOGOMAIL_STORAGE_S3_REGION=us-east-1
GOGOMAIL_STORAGE_S3_BUCKET=gogomail
GOGOMAIL_STORAGE_S3_ACCESS_KEY_ID=gogomail
GOGOMAIL_STORAGE_S3_SECRET_ACCESS_KEY=changepassword123
GOGOMAIL_STORAGE_S3_FORCE_PATH_STYLE=true
GOGOMAIL_DELIVERY_RECIPIENT_BATCH_SIZE=100
GOGOMAIL_MESSAGE_BODY_CACHE_ENTRIES=256
GOGOMAIL_MESSAGE_BODY_CACHE_TTL=5m
GOGOMAIL_OUTBOX_RELAY_BATCH_SIZE=100
GOGOMAIL_OUTBOX_RELAY_POLL_INTERVAL=5s
GOGOMAIL_AUTO_PURGE_ENABLED=false
GOGOMAIL_AUTO_PURGE_INTERVAL=24h
GOGOMAIL_AUTO_PURGE_BATCH_SIZE=1000
GOGOMAIL_CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3003
GOGOMAIL_METRICS_BACKEND=prometheus
GOGOMAIL_METRICS_ADDR=:9090
GOGOMAIL_WEBHOOK_DISPATCH_ENABLED=true
GOGOMAIL_SYSTEM_EMAIL_FROM=
GOGOMAIL_SYSTEM_SMTP_ADDR=
GOGOMAIL_SYSTEM_SMTP_USER=
GOGOMAIL_SYSTEM_SMTP_PASS=
GOGOMAIL_WEBPUSH_VAPID_PUBLIC_KEY=
GOGOMAIL_WEBPUSH_VAPID_PRIVATE_KEY=
GOGOMAIL_WEBPUSH_CONTACT_EMAIL=
GOGOMAIL_APNS_KEY_ID=
GOGOMAIL_APNS_TEAM_ID=
GOGOMAIL_APNS_PRIVATE_KEY=
GOGOMAIL_APNS_BUNDLE_ID=
# Backend component mode used when the container command does not pass --mode.
# If both APP_MODE and --mode are set, --mode takes precedence.
APP_MODE=all-in-one
APP_LOG_LEVEL=info
APP_PORT=8080

# ===== Backup / Release Verification =====
GOGOMAIL_BACKUP_DIR=./backups
GOGOMAIL_BACKUP_RETENTION_DAYS=7
GOGOMAIL_BACKUP_S3_BUCKET=
GOGOMAIL_BACKUP_S3_PREFIX=gogomail
GOGOMAIL_RESTORE_REHEARSAL_DATABASE_URL=
GOGOMAIL_RESTORE_REHEARSAL_DB_URL=
GOGOMAIL_RESTORE_REHEARSAL_KEEP_DB=0
GOGOMAIL_SECURITY_VERIFY=0

# ===== Admin Console (Next.js) =====
ADMIN_BACKEND_URL=http://localhost:8080

# ===== Development Port Overrides =====
GOGOMAIL_DEV_POSTGRES_PORT=15432
GOGOMAIL_DEV_REDIS_PORT=16379
GOGOMAIL_DEV_MINIO_PORT=19000
GOGOMAIL_DEV_MINIO_CONSOLE_PORT=19001
GOGOMAIL_DEV_BACKEND_PORT=8080

# ===== Prometheus =====
PROMETHEUS_RETENTION_TIME=30d

# ===== Large Deployment Specific =====
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
ELASTICSEARCH_MEMORY=512m
ELASTICSEARCH_HEAP_SIZE=512m
ELK_VERSION=8.0.0

# ===== Docker Images =====
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
MINIO_IMAGE=minio/minio:latest
MINIO_MC_IMAGE=minio/mc:latest
NGINX_IMAGE=nginx:alpine
PROMETHEUS_IMAGE=prom/prometheus:latest
GRAFANA_IMAGE=grafana/grafana:latest
ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.0.0
KIBANA_IMAGE=docker.elastic.co/kibana/kibana:8.0.0
LOGSTASH_IMAGE=docker.elastic.co/logstash/logstash:8.0.0

# ===== AWS CloudWatch (Large Deployment) =====
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# CLOUDWATCH_LOG_GROUP=/gogomail/backend
# CLOUDWATCH_LOG_STREAM=backend-stream

# ===== SSL/TLS =====
# NGINX_SSL_CERT_PATH=./certs/cert.pem
# NGINX_SSL_KEY_PATH=./certs/key.pem

# ===== Custom Settings =====
# Add deployment-specific settings below
