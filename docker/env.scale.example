# GoGoMail split-mode deployment environment.
#
# Copy to docker/.env, then change only values here and in Compose profiles:
#   cp env.scale.example .env
#
# Local evaluation:
#   docker compose -f docker-compose.scale.yml --profile local-infra --profile protocols --profile workers up -d
#
# Production:
#   - set GOGOMAIL_ENV=production
#   - use sslmode=require or verify-full for Postgres
#   - use HTTPS S3/MinIO endpoint or managed S3
#   - keep GOGOMAIL_FARM_COORDINATOR_BACKEND=redis

# ===== Image =====
BACKEND_IMAGE=gogomail:latest

# ===== Environment =====
GOGOMAIL_ENV=development
GOGOMAIL_PUBLIC_BASE_URL=http://localhost:8080
GOGOMAIL_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
GOGOMAIL_AUTH_JWT_SECRET=gogomail-dev-jwt-secret-at-least-32-bytes
GOGOMAIL_ADMIN_TOKEN=change-this-admin-token
GOGOMAIL_ADMIN_MFA_REQUIRED=false

# ===== PostgreSQL =====
POSTGRES_DB=gogomail
POSTGRES_USER=gogomail
POSTGRES_PASSWORD=gogomail
GOGOMAIL_POSTGRES_PORT=5432
GOGOMAIL_DATABASE_URL=postgres://gogomail:gogomail@postgres:5432/gogomail?sslmode=disable
GOGOMAIL_DB_MAX_OPEN_CONNS=20
GOGOMAIL_DB_MAX_IDLE_CONNS=5
GOGOMAIL_DB_CONN_MAX_LIFETIME=30m
GOGOMAIL_DB_CONN_MAX_IDLE_TIME=5m

# ===== Redis =====
GOGOMAIL_REDIS_ADDR=redis:6379
GOGOMAIL_REDIS_PASSWORD=gogomail
GOGOMAIL_REDIS_SENTINEL_ADDRS=
GOGOMAIL_REDIS_MASTER_NAME=mymaster
GOGOMAIL_REDIS_PORT=6379

# ===== Object storage =====
MINIO_ROOT_USER=gogomail
MINIO_ROOT_PASSWORD=gogomail123
GOGOMAIL_MINIO_PORT=9000
GOGOMAIL_MINIO_CONSOLE_PORT=9001
GOGOMAIL_STORAGE_BACKEND=minio
GOGOMAIL_STORAGE_S3_ENDPOINT=http://minio:9000
GOGOMAIL_STORAGE_S3_REGION=us-east-1
GOGOMAIL_STORAGE_S3_BUCKET=gogomail
GOGOMAIL_STORAGE_S3_PREFIX=
GOGOMAIL_STORAGE_S3_ACCESS_KEY_ID=gogomail
GOGOMAIL_STORAGE_S3_SECRET_ACCESS_KEY=gogomail123
GOGOMAIL_STORAGE_S3_FORCE_PATH_STYLE=true
GOGOMAIL_STORAGE_S3_INSECURE_SKIP_VERIFY=false

# ===== Public protocol identity =====
GOGOMAIL_SMTP_DOMAIN=localhost
GOGOMAIL_DELIVERY_SMTP_HELLO=localhost
GOGOMAIL_DELIVERY_TLS_MODE=opportunistic

# ===== Scale coordination =====
GOGOMAIL_FARM_COORDINATOR_BACKEND=redis
GOGOMAIL_OUTBOX_RELAY_BATCH_SIZE=100
GOGOMAIL_OUTBOX_RELAY_POLL_INTERVAL=1s
GOGOMAIL_OUTBOX_RELAY_MAX_ATTEMPTS=10

# These values are per process. For many replicas, keep each replica's
# DB connections low enough that sum(replicas * max_open_conns) fits Postgres.
GOGOMAIL_DELIVERY_CONSUMER_COUNT=50
GOGOMAIL_EVENT_CONSUMER_COUNT=100
GOGOMAIL_SEARCH_INDEX_CONSUMER_COUNT=50
GOGOMAIL_PUSH_NOTIFICATION_CONSUMER_COUNT=50
GOGOMAIL_API_METERING_CONSUMER_COUNT=100

# Redis-backed coordination keeps delivery limits shared across workers.
GOGOMAIL_DELIVERY_THROTTLE_ENABLED=true
GOGOMAIL_DELIVERY_THROTTLE_BACKEND=redis
GOGOMAIL_DELIVERY_DOMAIN_BACKOFF_ENABLED=true
GOGOMAIL_DELIVERY_DOMAIN_BACKOFF_BACKEND=redis
GOGOMAIL_DRIVE_SHARE_RATELIMIT_BACKEND=redis
GOGOMAIL_MAIL_MUTATION_RATELIMIT_BACKEND=redis

# ===== Optional search and push =====
GOGOMAIL_SEARCH_INDEX_BACKEND=disabled
GOGOMAIL_SEARCH_INDEX_OPENSEARCH_ENDPOINT=
GOGOMAIL_SEARCH_INDEX_OPENSEARCH_INDEX=gogomail-messages
GOGOMAIL_API_METERING_BACKEND=redis
GOGOMAIL_API_METERING_AGGREGATE_BACKEND=postgres
GOGOMAIL_WEBPUSH_VAPID_PUBLIC_KEY=
GOGOMAIL_WEBPUSH_VAPID_PRIVATE_KEY=
GOGOMAIL_WEBPUSH_CONTACT_EMAIL=
GOGOMAIL_APNS_KEY_ID=
GOGOMAIL_APNS_TEAM_ID=
GOGOMAIL_APNS_PRIVATE_KEY=
GOGOMAIL_APNS_BUNDLE_ID=

# ===== Host port ranges =====
# Ranges keep `docker compose --scale service=N` from colliding on host ports.
# In production, put a load balancer in front and point it at these published
# ports or run the same services on separate hosts.
GOGOMAIL_MAIL_API_PORT_RANGE=8080-8089
GOGOMAIL_ADMIN_API_PORT_RANGE=8090-8099
GOGOMAIL_AUTH_SERVER_PORT_RANGE=8100-8109
GOGOMAIL_EDGE_SMTP_PORT_RANGE=2525-2534
GOGOMAIL_SUBMISSION_PORT_RANGE=2587-2596
GOGOMAIL_IMAP_PORT_RANGE=1143-1152
GOGOMAIL_POP3_PORT_RANGE=1110-1119
GOGOMAIL_CALDAV_PORT_RANGE=8110-8119
GOGOMAIL_CARDDAV_PORT_RANGE=8120-8129
GOGOMAIL_WEBDAV_PORT_RANGE=8130-8139

# ===== Images for optional local infrastructure =====
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
MINIO_IMAGE=minio/minio:latest
MINIO_MC_IMAGE=minio/mc:latest
