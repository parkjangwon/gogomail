# GoGoMail Admin Console Environment Variables

# Backend API URL
GOGOMAIL_BACKEND_URL=http://localhost:8080

# Public origin displayed in generated links/copy
NEXT_PUBLIC_GOGOMAIL_PUBLIC_BASE_URL=http://localhost:3001

# Node environment
NODE_ENV=development

# Build ID (for versioning across distributed instances)
# GIT_SHA=abc123def456

# Admin console mode: "saas" (multi-tenant) or "selfhosted" (single-tenant)
# Required for production deployment
GOGOMAIL_ADMIN_MODE=saas

# Encryption key for sensitive config at rest (min 32 chars, random hex)
# Generate with: openssl rand -hex 32
# GOGOMAIL_ENCRYPTION_KEY=

# Initial admin token (set on first deploy, rotate after initial setup)
# GOGOMAIL_ADMIN_INITIAL_TOKEN=
