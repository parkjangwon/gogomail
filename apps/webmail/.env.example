# Backend API URL (server-side proxy target)
GOGOMAIL_BACKEND_URL=http://localhost:8080

# VAPID Public Key for Web Push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Public product/help origin used by browser-visible links
NEXT_PUBLIC_GOGOMAIL_PUBLIC_BASE_URL=http://localhost:3003

# Development only: skip authentication (set to "true" to enable)
NEXT_PUBLIC_GOGOMAIL_DEV_SKIP_LOGIN=false

# Development only: hardcoded user ID when skipping login
# Also exposed as GOGOMAIL_DEV_USER_ID for server-side API routes
NEXT_PUBLIC_GOGOMAIL_DEV_USER_ID=
GOGOMAIL_DEV_USER_ID=

# Optional: Webmail guide URL shown in help section
NEXT_PUBLIC_WEBMAIL_GUIDE_URL=
