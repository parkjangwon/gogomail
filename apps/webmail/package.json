{
  "name": "@gogomail/webmail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/check-frontend-node-version.mjs",
    "dev": "next dev --webpack -p 3003",
    "prebuild": "node ../../scripts/check-frontend-node-version.mjs",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "pnpm test:compose-helpers && pnpm test:mail-page-helpers && pnpm test:security-helpers && pnpm test:compose-utils && pnpm test:send-result-label && pnpm test:stableid-timezone && pnpm test:drive-helpers",
    "test:compose-helpers": "node --experimental-strip-types scripts/check-compose-helpers.mjs",
    "test:mail-page-helpers": "node --experimental-strip-types scripts/check-mail-page-helpers.mjs",
    "test:security-helpers": "node --experimental-strip-types scripts/check-security-helpers.mjs",
    "test:compose-utils": "node --experimental-strip-types scripts/check-compose-utils.mjs",
    "test:drive-helpers": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/check-drive-helpers.mjs",
    "test:send-result-label": "node --experimental-strip-types scripts/check-send-result-label.mjs",
    "test:stableid-timezone": "node --experimental-strip-types scripts/check-stableid-timezone.mjs",
    "test:datetime-local": "pnpm test:compose-helpers",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.100.9",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@types/dompurify": "^3.2.0",
    "@untitledui/file-icons": "^0.0.9",
    "dompurify": "^3.4.2",
    "fflate": "^0.8.2",
    "next": "^16.2.6",
    "next-intl": "^4.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
